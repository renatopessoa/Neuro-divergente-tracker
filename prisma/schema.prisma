generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  email        String       @unique
  passwordHash String
  role         String       @default("ADMIN")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  checkIns     CheckIn[]
  medications  Medication[]
  behaviorLogs BehaviorLog[]
}

model CheckIn {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date         DateTime @default(now())
  mood         Int
  painLevel    Int
  sleepHours   Float
  sleepQuality Int
  dietNotes    String?
  symptoms     String[]
  generalNotes String?
  createdAt    DateTime @default(now())
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Medication {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  dosage    String
  frequency String
  time      String
  createdAt DateTime @default(now())
  userId    String   @db.Uuid
  logs      MedLog[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MedLog {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date       DateTime   @default(now())
  taken      Boolean    @default(true)
  medId      String     @db.Uuid
  medication Medication @relation(fields: [medId], references: [id], onDelete: Cascade)
}

model BehaviorLog {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                String   @db.Uuid
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())

  // 1. Contexto e Identificação
  timestamp             DateTime @default(now())
  location              String?
  peoplePresent         String?
  
  // NOVO: Nível de Alerta Pré-Evento
  preCrisisArousal      Int?     // Escala 1-10: 1=Muito baixo/letárgico, 10=Muito alto/hiperativo

  // 2. Antecedente (O Gatilho)
  vulnerabilityFactors  String[]
  perceivedTriggers     String[]
  
  // NOVO: Tipo de Sobrecarga Sensorial
  sensorOverloadTypes   String[] // Ex: ["Visual", "Auditiva", "Tátil", "Olfativa", "Proprioceptiva", "Vestibular"]

  // 3. Topografia do Comportamento (A Crise)
  eventType             String
  description           String?
  durationMinutes       Int?
  intensity             Int

  // 4. Consequência e Resposta
  copingStrategies      String[]
  efficacy              Int?
  environmentReaction   String?
  
  // NOVO: Tradução Simultânea (como explicar para um neurotípico)
  neurotypicalTranslation String? // Ex: "Tive uma sobrecarga sensorial" → "Não consegui processar múltiplos estímulos ao mesmo tempo"
  
  // NOVO: Impacto em Funções Executivas
  executiveFunctionImpact String[] // Ex: ["Iniciação de tarefas", "Memória de trabalho", "Foco/Atenção", "Organização"]

  // 5. Notas Adicionais e Observações
  warningSigns          String?
  postCrisisState       String?
  notes                 String?
}
