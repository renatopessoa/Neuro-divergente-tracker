generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String
  email         String    @unique
  passwordHash  String
  role          String    @default("ADMIN")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  checkIns      CheckIn[]
  medications   Medication[]
}

model CheckIn {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date         DateTime @default(now())
  mood         Int      // 1-5
  painLevel    Int      // 0-10
  sleepHours   Float
  sleepQuality Int      // 1-5
  dietNotes    String?  @db.Text
  symptoms     String[]
  generalNotes String?  @db.Text
  createdAt    DateTime @default(now())
  
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Medication {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  dosage       String
  frequency    String
  time         String   // HH:mm
  createdAt    DateTime @default(now())
  
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs         MedLog[]
}

model MedLog {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date         DateTime @default(now())
  taken        Boolean  @default(true)
  
  medId        String   @db.Uuid
  medication   Medication @relation(fields: [medId], references: [id], onDelete: Cascade)
}
