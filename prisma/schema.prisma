generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  email        String       @unique
  passwordHash String
  role         String       @default("ADMIN")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  checkIns     CheckIn[]
  medications  Medication[]
  behaviorLogs BehaviorLog[]
}

model CheckIn {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date         DateTime @default(now())
  mood         Int
  painLevel    Int
  sleepHours   Float
  sleepQuality Int
  dietNotes    String?
  symptoms     String[]
  generalNotes String?
  createdAt    DateTime @default(now())
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Medication {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  dosage    String
  frequency String
  time      String
  createdAt DateTime @default(now())
  userId    String   @db.Uuid
  logs      MedLog[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MedLog {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date       DateTime   @default(now())
  taken      Boolean    @default(true)
  medId      String     @db.Uuid
  medication Medication @relation(fields: [medId], references: [id], onDelete: Cascade)
}

model BehaviorLog {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  timestamp         DateTime @default(now())
  eventType         String
  description       String?
  perceivedTriggers String[]
  intensity         Int
  durationMinutes   Int?
  copingStrategies  String[]
  notes             String?
  createdAt         DateTime @default(now())
  userId            String   @db.Uuid
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
