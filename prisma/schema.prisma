generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
}

model User {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("ADMIN")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  behaviorLogs BehaviorLog[]
  checkIns     CheckIn[]
  medications  Medication[]
}

model CheckIn {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date         DateTime @default(now())
  mood         Int
  painLevel    Int
  sleepHours   Float
  sleepQuality Int
  dietNotes    String?
  symptoms     String[]
  generalNotes String?
  createdAt    DateTime @default(now())
  userid       String   @db.Uuid
  user         User     @relation(fields: [userid], references: [id], onDelete: Cascade)

}

model Medication {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  dosage    String
  frequency String
  time      String
  createdAt DateTime @default(now())
  userId    String   @db.Uuid
  logs      MedLog[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MedLog {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date       DateTime   @default(now())
  taken      Boolean    @default(true)
  medId      String     @db.Uuid
  medication Medication @relation(fields: [medId], references: [id], onDelete: Cascade)
}

model BehaviorLog {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                  String   @db.Uuid
  timestamp               DateTime @default(now())
  eventType               String
  description             String?
  perceivedTriggers       String[]
  intensity               Int
  durationMinutes         Int?
  copingStrategies        String[]
  notes                   String?
  createdAt               DateTime @default(now())
  efficacy                Int?
  environmentReaction     String?
  location                String?
  peoplePresent           String?
  postCrisisState         String?
  vulnerabilityFactors    String[]
  warningSigns            String?
  executiveFunctionImpact String[]
  neurotypicalTranslation String?
  preCrisisArousal        Int?
  sensorOverloadTypes     String[]
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
